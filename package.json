{
  "name": "mouse-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "http-server ./ -p 8080 -c-1",
    "lint": "eslint \"src/**/*.js\"",
    "format": "prettier --write \"**/*.{js,css,md,json}\"",
    "test:playwright": "npx playwright install --with-deps && npx http-server ./ -p 8080 -c-1 & npx playwright test --config=tests/playwright.config.js",
    "harness": "node scripts/level_harness.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "eslint": "^8.0.0",
    "http-server": "^14.0.0",
    "prettier": "^2.0.0"
  }
}